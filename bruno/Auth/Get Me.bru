meta {
  name: Get Me
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/api/auth/me
  body: none
  auth: bearer
}

params:query {
  ~lang: es
}

headers {
  ~Accept-Language: en
}

auth:bearer {
  token: {{token}}
}

tests {
  test("Debería obtener los datos del usuario autenticado", function() {
    expect(res.getStatus()).to.equal(200);
  });
  
  test("Debería incluir el rol del usuario", function() {
    expect(res.getBody().role).to.be.oneOf(['usuario', 'admin']);
  });
}
