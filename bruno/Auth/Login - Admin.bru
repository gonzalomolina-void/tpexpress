meta {
  name: Login - Admin
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

params:query {
  ~lang: es
}

headers {
  ~Accept-Language: en
}

body:json {
  {
    "email": "admin@example.com",
    "password": "password123"
  }
}

tests {
  test("Debería iniciar sesión correctamente", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Debería incluir el token JWT", function() {
    expect(res.getBody().token).to.be.a('string');
  });

  test("Debería incluir los datos del usuario con su rol", function() {
    expect(res.getBody().user).to.be.an('object');
    expect(res.getBody().user.role).to.equal('admin');
  });

  if (res.status === 200 && res.body.token) {
    bru.setVar("token", res.body.token);
  }
}
