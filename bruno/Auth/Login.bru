meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "testuser@example.com",
    "password": "password123"
  }
}

tests {
  if (res.status === 200 && res.body.token) {
    bru.setVar("token", res.body.token);
  }
}
