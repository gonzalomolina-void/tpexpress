meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "testuser@example.com",
    "password": "password123"
  }
}

tests {
  test("Debería registrar un usuario correctamente", function() {
    expect(res.getStatus()).to.equal(201);
  });

  test("Debería incluir el rol del usuario por defecto", function() {
    expect(res.getBody().role).to.equal("usuario");
  });
}
