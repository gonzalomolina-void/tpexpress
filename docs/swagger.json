{
  "openapi": "3.0.0",
  "info": {
    "title": "TPExpress API",
    "version": "1.0.0",
    "description": "API REST para gestionar cartas coleccionables, desarrollada para la materia PWA (Universidad Nacional del Comahue). Reemplaza la persistencia en localStorage por una base de datos PostgreSQL persistida en tiempo real con Prisma ORM."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor de Desarrollo Local"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Verificar la salud de la API",
        "description": "Retorna el estado de disponibilidad del servidor.",
        "responses": {
          "200": {
            "description": "API funcionando correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" },
                    "message": { "type": "string", "example": "API funcionando correctamente" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/about": {
      "get": {
        "summary": "Obtener información del proyecto y del equipo de desarrollo",
        "description": "Retorna los datos de los desarrolladores del proyecto, sus roles y una frase estoica filosófica. Soporta internacionalización (mediante query parameter o cabecera HTTP Accept-Language).",
        "parameters": [
          {
            "name": "lang",
            "in": "query",
            "description": "Idioma preferido para los textos ('es' o 'en').",
            "required": false,
            "schema": { "type": "string", "enum": ["es", "en"] }
          },
          {
            "name": "Accept-Language",
            "in": "header",
            "description": "Idioma preferido alternativo ('es' o 'en'). Por defecto es 'es'.",
            "required": false,
            "schema": { "type": "string", "enum": ["es", "en"], "default": "es" }
          }
        ],
        "responses": {
          "200": {
            "description": "Información obtenida correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/About"
                }
              }
            }
          }
        }
      }
    },
    "/api/cards": {
      "get": {
        "summary": "Obtener catálogo de cartas",
        "description": "Retorna el listado de cartas. Soporta internacionalización (mediante la cabecera Accept-Language) y paginación opcional. Si no se envía paginación, retorna todo el catálogo limitado a un tope de seguridad de 500 registros.",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Número de página a retornar (1-indexed). Se requiere junto con limit.",
            "required": false,
            "schema": { "type": "integer", "minimum": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Cantidad de elementos por página. Se requiere junto con page.",
            "required": false,
            "schema": { "type": "integer", "minimum": 1 }
          },
          {
            "name": "search",
            "in": "query",
            "description": "Término de búsqueda parcial sobre el nombre de la carta (case-insensitive).",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "type",
            "in": "query",
            "description": "Filtro exacto por código del tipo de carta.",
            "required": false,
            "schema": { "type": "string", "enum": ["creature", "spell", "artifact"] }
          },
          {
            "name": "rarity",
            "in": "query",
            "description": "Filtro exacto por código de la rareza de la carta.",
            "required": false,
            "schema": { "type": "string", "enum": ["poor", "common", "uncommon", "rare", "epic", "legendary"] }
          },
          {
            "name": "lang",
            "in": "query",
            "description": "Idioma preferido para los textos de las cartas ('es' o 'en'). Alternativa a Accept-Language.",
            "required": false,
            "schema": { "type": "string", "enum": ["es", "en"] }
          },
          {
            "name": "Accept-Language",
            "in": "header",
            "description": "Idioma preferido para los textos de las cartas ('es' o 'en'). Por defecto es 'es'.",
            "required": false,
            "schema": { "type": "string", "enum": ["es", "en"], "default": "es" }
          }
        ],
        "responses": {
          "200": {
            "description": "Listado de cartas obtenido correctamente",
            "headers": {
              "X-Total-Count": {
                "schema": { "type": "integer" },
                "description": "Total general de cartas disponibles en la base de datos (solo se incluye cuando la petición es paginada)."
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Card" }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Crear una nueva carta",
        "description": "Crea una carta nueva con sus traducciones en múltiples idiomas. Requiere rol admin.",
        "tags": ["Cards"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["cost", "atk", "def", "image", "typeId", "rarityId", "translations"],
                "properties": {
                  "cost": { "type": "integer", "minimum": 0, "example": 5 },
                  "atk": { "type": "integer", "minimum": 0, "example": 8 },
                  "def": { "type": "integer", "minimum": 0, "example": 10 },
                  "image": { "type": "string", "example": "SirKaelen.webp" },
                  "typeId": { "type": "integer", "minimum": 1, "example": 1 },
                  "rarityId": { "type": "integer", "minimum": 1, "example": 1 },
                  "translations": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": ["language", "name", "description"],
                      "properties": {
                        "language": { "type": "string", "enum": ["es", "en"], "example": "es" },
                        "name": { "type": "string", "example": "Sir Kaelen" },
                        "description": { "type": "string", "example": "El último guardián del Sol Blanco" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Carta creada exitosamente",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Card" }
              }
            }
          },
          "400": {
            "description": "Datos inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "Datos inválidos" },
                    "details": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "field": { "type": "string" },
                          "message": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "No autorizado (token faltante, inválido o expirado)"
          },
          "403": {
            "description": "Acceso prohibido (se requiere rol admin)"
          },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },
    "/api/cards/{id}": {
      "get": {
        "summary": "Obtener detalle de una carta por ID",
        "description": "Retorna la información completa de una carta específica mapeada al idioma solicitado.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Identificador entero único de la carta.",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "Accept-Language",
            "in": "header",
            "description": "Idioma preferido para los textos de la carta ('es' o 'en').",
            "required": false,
            "schema": { "type": "string", "enum": ["es", "en"], "default": "es" }
          }
        ],
        "responses": {
          "200": {
            "description": "Detalle de la carta obtenido correctamente",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Card" }
              }
            }
          },
          "400": {
            "description": "ID inválido (no es un entero)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "Datos inválidos" },
                    "details": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "field": { "type": "string", "example": "id" },
                          "message": { "type": "string", "example": "El ID de la carta debe ser un número entero válido" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Carta no encontrada",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "Recurso no encontrado" }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Actualizar una carta existente",
        "description": "Actualiza los datos de una carta existente incluyendo sus traducciones. Requiere rol admin.",
        "tags": ["Cards"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["cost", "atk", "def", "image", "typeId", "rarityId", "translations"],
                "properties": {
                  "cost": { "type": "integer", "minimum": 0, "example": 5 },
                  "atk": { "type": "integer", "minimum": 0, "example": 8 },
                  "def": { "type": "integer", "minimum": 0, "example": 10 },
                  "image": { "type": "string", "example": "SirKaelen.webp" },
                  "typeId": { "type": "integer", "minimum": 1, "example": 1 },
                  "rarityId": { "type": "integer", "minimum": 1, "example": 1 },
                  "translations": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": ["language", "name", "description"],
                      "properties": {
                        "language": { "type": "string", "enum": ["es", "en"], "example": "es" },
                        "name": { "type": "string", "example": "Sir Kaelen" },
                        "description": { "type": "string", "example": "El último guardián del Sol Blanco" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Carta actualizada exitosamente",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Card" }
              }
            }
          },
          "400": {
            "description": "Datos inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "Datos inválidos" },
                    "details": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "field": { "type": "string" },
                          "message": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "No autorizado (token faltante, inválido o expirado)"
          },
          "403": {
            "description": "Acceso prohibido (se requiere rol admin)"
          },
          "404": {
            "description": "Recurso no encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "Recurso no encontrado" }
                  }
                }
              }
            }
          },
          "500": { "description": "Error interno del servidor" }
        }
      },
      "delete": {
        "summary": "Eliminar una carta",
        "description": "Elimina una carta de la base de datos. Requiere rol admin.",
        "tags": ["Cards"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Carta eliminada exitosamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Carta eliminada correctamente" }
                  }
                }
              }
            }
          },
          "401": {
            "description": "No autorizado (token faltante, inválido o expirado)"
          },
          "403": {
            "description": "Acceso prohibido (se requiere rol admin)"
          },
          "404": {
            "description": "Recurso no encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string", "example": "Recurso no encontrado" }
                  }
                }
              }
            }
          },
          "500": { "description": "Error interno del servidor" }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Registrar un nuevo usuario",
        "description": "Crea una nueva cuenta de usuario en el sistema. Valida que el email tenga un formato correcto y no esté duplicado, y que la contraseña sea segura (mínimo 6 caracteres).",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "usuario@example.com"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 6,
                    "example": "password123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuario registrado exitosamente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Datos inválidos o email ya registrado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Datos invalidos"
                    },
                    "details": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "field": {
                            "type": "string",
                            "example": "email"
                          },
                          "message": {
                            "type": "string",
                            "example": "El formato del email es invalido"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Iniciar sesión",
        "description": "Autentica un usuario con sus credenciales (email y contraseña), retornando un Access Token JWT válido por 15 minutos en el JSON e inyectando una cookie segura httpOnly 'refreshToken' válida por 7 días.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "email",
                  "password"
                ],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "usuario@example.com"
                  },
                  "password": {
                    "type": "string",
                    "example": "password123"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Sesión iniciada correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    },
                    "user": {
                      "$ref": "#/components/schemas/User"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Credenciales incompletas",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Credenciales incompletas"
                    },
                    "message": {
                      "type": "string",
                      "example": "Debes proporcionar email y contraseña"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Credenciales inválidas",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Credenciales invalidas"
                    },
                    "message": {
                      "type": "string",
                      "example": "El email o la contraseña son incorrectos"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "summary": "Refrescar token de acceso",
        "description": "Utiliza el Refresh Token recibido en la cookie segura httpOnly para generar un nuevo Access Token JWT válido.",
        "responses": {
          "200": {
            "description": "Token refrescado correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": {
                      "type": "string",
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Sesión expirada o inválida",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "No autorizado"
                    },
                    "message": {
                      "type": "string",
                      "example": "Sesión expirada o inválida"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "summary": "Cerrar sesión",
        "description": "Invalida el Refresh Token del usuario en la base de datos y remueve la cookie de sesión del cliente.",
        "responses": {
          "200": {
            "description": "Sesión cerrada correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "example": "Sesión cerrada correctamente"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "summary": "Obtener información del usuario autenticado",
        "description": "Retorna el perfil del usuario correspondiente al token JWT provisto en la cabecera Authorization.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Perfil de usuario obtenido correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "401": {
            "description": "No autorizado (token faltante, inválido o expirado)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string",
                      "example": "Token invalido"
                    },
                    "message": {
                      "type": "string",
                      "example": "El token de autenticacion provisto es invalido o ha expirado"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/favorites": {
      "get": {
        "summary": "Obtener catálogo de cartas favoritas",
        "description": "Retorna el listado de cartas favoritas del usuario autenticado mapeadas al idioma solicitado.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "Accept-Language",
            "in": "header",
            "description": "Idioma preferido para los textos de las cartas ('es' o 'en'). Por defecto es 'es'.",
            "required": false,
            "schema": { "type": "string", "enum": ["es", "en"], "default": "es" }
          }
        ],
        "responses": {
          "200": {
            "description": "Listado de favoritos obtenido correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Card" }
                }
              }
            }
          },
          "401": {
            "description": "No autorizado (token faltante, inválido o expirado)"
          }
        }
      },
      "post": {
        "summary": "Agregar una carta a favoritos",
        "description": "Asocia la carta especificada en el body por cardId al listado de favoritos del usuario autenticado de forma idempotente.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["cardId"],
                "properties": {
                  "cardId": {
                    "type": "integer",
                    "example": 3
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Carta agregada a favoritos correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Carta agregada a favoritos correctamente" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Datos inválidos (ID inválido)"
          },
          "401": {
            "description": "No autorizado"
          },
          "404": {
            "description": "Carta no encontrada"
          }
        }
      }
    },
    "/api/favorites/{cardId}": {
      "delete": {
        "summary": "Eliminar una carta de favoritos",
        "description": "Remueve la relación de favorito entre el usuario autenticado y la carta indicada por cardId de forma idempotente.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "cardId",
            "in": "path",
            "description": "Identificador entero único de la carta.",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Carta eliminada de favoritos correctamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": { "type": "string", "example": "Carta eliminada de favoritos correctamente" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Datos inválidos (ID inválido)"
          },
          "401": {
            "description": "No autorizado"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
