{
  "name": "hexa-tcg-api",
  "version": "1.6.0",
  "description": "API REST oficial para Hexa TCG, proporcionando soporte para gestión de cartas, autenticación de usuarios, favoritos y más, con persistencia en base de datos PostgreSQL mediante Prisma ORM.",
  "main": "src/index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "nodemon src/index.js",
    "dev:debug": "nodemon --inspect=0.0.0.0:9229 src/index.js",
    "start": "node src/index.js",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "release:patch": "powershell -ExecutionPolicy Bypass -File ./scripts/Release-Project.ps1 -ReleaseType patch",
    "release:minor": "powershell -ExecutionPolicy Bypass -File ./scripts/Release-Project.ps1 -ReleaseType minor",
    "release:major": "powershell -ExecutionPolicy Bypass -File ./scripts/Release-Project.ps1 -ReleaseType major",
    "db:update-users": "node scripts/Update-Users.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gonzalomolina-void@github.com/gonzalomolina-void/tpexpress.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/gonzalomolina-void/tpexpress/issues"
  },
  "homepage": "https://github.com/gonzalomolina-void/tpexpress#readme",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "i18next": "^26.3.1",
    "i18next-http-middleware": "^3.9.7",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "standard-version": "^9.5.0",
    "vitest": "^4.1.8"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f",
  "engines": {
    "node": "22.x"
  }
}
